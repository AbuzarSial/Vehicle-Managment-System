{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd VMS/frontend && npm ci --include=dev",
  "buildCommand": "cd VMS/frontend && npm run build",
  "outputDirectory": "VMS/frontend/dist",
  "trailingSlash": false,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
