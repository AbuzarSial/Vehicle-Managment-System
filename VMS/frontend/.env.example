# Backend API base (no trailing slash).
# Recommended for local dev: Vite dev server + proxy in vite.config.js (same origin, no CORS issues on 5xx).
VITE_API_BASE_URL=http://127.0.0.1:5173
# Alternative: call FastAPI directly (ensure backend CORS allow_origins matches your dev origin).
# VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_APP_NAME=Vehicle Service Management
