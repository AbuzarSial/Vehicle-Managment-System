# Optional: API origin (no trailing slash). Omit for local dev = same-origin `/api/...` (recommended).
# Works whether you open http://localhost:5173 or http://127.0.0.1:5173 with Vite’s proxy to FastAPI :8000.
# VITE_API_BASE_URL=

# Call FastAPI directly (optional; then enable CORS for your browser origin on the backend):
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Production SPA calling a hosted API:
# VITE_API_BASE_URL=https://your-api.example.com

VITE_APP_NAME=Vehicle Service Management
