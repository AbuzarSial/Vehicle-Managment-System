# Backend API base (no trailing slash).
# Local dev: same origin as Vite so /api proxies to FastAPI (vite.config.js).
VITE_API_BASE_URL=http://127.0.0.1:5173
# Local direct API (set backend CORS / CORS_ALLOW_ORIGINS if browser origin differs):
# VITE_API_BASE_URL=http://127.0.0.1:8000
# Production (e.g. Vercel SPA calling a hosted FastAPI URL):
# VITE_API_BASE_URL=https://your-api.example.com
VITE_APP_NAME=Vehicle Service Management
