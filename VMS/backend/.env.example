# Copy to .env and set DATABASE_URL.

APP_NAME=Vehicle Service Management API

# --- Local MySQL (database/schema/*.sql) ---
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/vms_db
# DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/vms_db

# --- Neon PostgreSQL (database/postgres/*.sql) ---
# Use SQLAlchemy + psycopg driver. Include sslmode=require.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: comma-separated browser origins allowed by CORS (production SPA), e.g.:
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app
# All Vercel previews + production on *.vercel.app (recommended if you use PR deployments):
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
