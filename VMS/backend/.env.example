# Copy to .env and adjust credentials for your local MySQL instance.
APP_NAME=Vehicle Service Management API
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/vms_db
# Homebrew fresh install uses insecure empty root password until mysql_secure_installation:
# DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/vms_db
