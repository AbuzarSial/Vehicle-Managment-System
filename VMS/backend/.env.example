# Copy to .env and set DATABASE_URL for MySQL.

APP_NAME=Vehicle Service Management API

# MySQL (database name vms_db). SQLAlchemy driver: mysql+pymysql:// only — not PostgreSQL.
# Local — apply scripts from database/schema/ and database/seed/ (see database/README.md)
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/vms_db
# DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/vms_db
# Render + external MySQL (example — URL-encode special characters in password):
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOSTNAME.region.psdb.cloud:3306/vms_db

# Optional: comma-separated extra browser origins for CORS (staging, preview URLs, etc.)
# Production Vercel origin is already allowed in app/main.py defaults.
# CORS_ALLOW_ORIGINS=https://another-preview.vercel.app
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
